# MongoDB - URI de conexión a MongoDB Atlas
MONGODB_URI=mongodb+srv://usuario:password@cluster.mongodb.net/templojireh?retryWrites=true&w=majority

# NextAuth - Generar con: openssl rand -base64 32
NEXTAUTH_SECRET=tu-secret-aqui

# NextAuth - URL del sitio (cambiar en producción)
NEXTAUTH_URL=http://localhost:3000

# Credenciales del administrador
ADMIN_EMAIL=admin@templojireh.com
ADMIN_PASSWORD=tu-password-seguro

# Resend - API Key para envío de emails (https://resend.com)
RESEND_API_KEY=re_xxxxxxxxxxxx

# YouTube Data API v3 - Para detectar transmisiones en vivo
YOUTUBE_API_KEY=AIzaSy...
